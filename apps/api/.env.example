IS_LOCAL=true
STAGE=dev
AWS_REGION=sa-east-1
DYNAMODB_TABLE_NAME=horizons-dev-table
S3_BUCKET_NAME=horizons-dev-fotos
FRONTEND_URL=http://localhost:5173
PORT=3000

# Segredos sensíveis NÃO ficam aqui em produção.
# Em produção são armazenados no SSM Parameter Store em /horizons/prod/<CHAVE>
# Para dev local, crie um .env (não commitado) com:
# ASAAS_API_KEY=
# STRIPE_SECRET_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# PAGARME_API_KEY=
# PAGBANK_TOKEN=
# PAGBANK_EMAIL=
# PICPAY_TOKEN=
# PICPAY_SELLER_TOKEN=
# SUMUP_API_KEY=
# BANCO_INTER_CLIENT_ID=
# BANCO_INTER_CLIENT_SECRET=
# BANCO_INTER_PIX_KEY=
# STONE_API_KEY=
# INFINITEPAY_API_KEY=
# SES_FROM_EMAIL=
# JWT_SECRET=
# CLOUDFRONT_DOMAIN=
# CF_KEY_PAIR_ID=
# CF_PRIVATE_KEY=
